pipeline {
    agent any

    tools {
        maven 'Maven-Default'
    }

    environment {
        REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
        IMAGE_TAG = "${REGISTRY}/petclinic:staging-${env.GIT_COMMIT.take(7)}"
    }

    stages {
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Compile") {
            steps {
                sh 'mvn clean package -DskipTests=true'
            }
        }

        stage("Test") {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage("Sonar Analysis") {
            steps {
                withSonarQubeEnv('Default') {
                    sh "mvn org.sonarsource.scanner.maven:sonar-maven-plugin:3.7.0.1746:sonar"
                }
            }
        }

        stage("Quality Gate") {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage("Build Image") {
            steps {
                sh 'mvn spring-boot:build-image -Dspring-boot.build-image.imageName=${IMAGE_TAG}'
            }
        }

        stage("Push Image to Registry") {
            steps {
                withAWS(
                    region: env.AWS_REGION,
                    credentials: 'aws-credentials',
                    sessionToken: 'aws-session-token'
                ) {
                    ecrLogin()
                    sh 'docker push ${IMAGE_TAG}'
                }
            }
        }

        stage("Deploy to Local Staging") {
            steps {
                sh 'docker stop petclinic-staging || true'
                sh 'docker rm petclinic-staging || true'

                sh 'docker run -d --name petclinic-staging -p 8081:8080 petclinic:latest'
                echo 'PetClinic staging running at http://localhost:8081/'
            }
        }
    }
}