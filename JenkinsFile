pipeline {
    agent any

    tools {
        maven 'Default'
    }

    stages {
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Compile") {
            steps {
                sh 'mvn clean package -DskipTests=true'
            }
        }

        stage("Test") {
            steps {
                sh 'mvn test'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }

        stage("Sonar Analysis") {
            steps {
                withSonarQubeEnv('Default') {
                    sh 'mvn sonar:sonar'
                }
            }
        }

        stage("Quality Gate") {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}