pipeline {
    agent any

    tools {
        maven 'Default'
    }

    stages {
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Compile") {
            steps {
                sh 'mvn clean package -DskipTests=true'
            }
        }

        stage("Test") {
            steps {
                sh 'mvn test -Dspring-boot.run.profiles=h2'
                sh 'mvn test -Dspring-boot.run.profiles=mysql'
                sh 'mvn test -Dspring-boot.run.profiles=postgres'
            }
            post {
                always {
                    junit 'target/surefire-reports/*.xml'
                }
            }
        }
    }
}