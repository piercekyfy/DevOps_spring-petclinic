pipeline {
    agent any

    tools {
        maven 'Maven-Default'
        sonarScanner 'Sonar-Default' 
    }

    stages {
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Compile") {
            steps {
                sh 'mvn clean package -DskipTests=true'
            }
        }

        // stage("Test") {
        //     steps {
        //         sh 'mvn test'
        //     }
        //     post {
        //         always {
        //             junit 'target/surefire-reports/*.xml'
        //         }
        //     }
        // }

        stage("Sonar Analysis") {
            steps {
                withSonarQubeEnv('Default') {
                    sh "sonar-scanner"
                }
            }
        }

        stage("Quality Gate") {
            steps {
                timeout(time: 3, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}