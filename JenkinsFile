pipeline {
    agent any

    tools {
        maven 'Maven-Default'
    }

    environment {
        REGISTRY = "${env.AWS_ACCOUNT_ID}.dkr.ecr.${env.AWS_REGION}.amazonaws.com"
        IMAGE_TAG = "${REGISTRY}/petclinic:staging-${env.GIT_COMMIT.take(7)}"
    }

    stages {
        stage("Checkout") {
            steps{
                checkout scm
            }
        }

        stage("Compile") {
            steps {
                sh 'mvn clean package -DskipTests=true'
            }
        }
        // temp disabled for faster testing
        // stage("Test") {
        //     steps {
        //         sh 'mvn test'
        //     }
        //     post {
        //         always {
        //             junit 'target/surefire-reports/*.xml'
        //         }
        //     }
        // }

        // stage("Sonar Analysis") {
        //     steps {
        //         withSonarQubeEnv('Default') {
        //             sh "mvn org.sonarsource.scanner.maven:sonar-maven-plugin:3.7.0.1746:sonar"
        //         }
        //     }
        // }

        // stage("Quality Gate") {
        //     steps {
        //         timeout(time: 3, unit: 'MINUTES') {
        //             waitForQualityGate abortPipeline: true
        //         }
        //     }
        // }

        stage("Build Image") {
            steps {
                sh 'mvn spring-boot:build-image -Dspring-boot.build-image.imageName=${IMAGE_TAG} -Dmaven.test.skip=true'
            }
        }

        // Need to do ALL aws stuff manually because learner-lab doesn't allow IAM setup
        // and no plugins allow a session-token to be manually configured !
        stage("Push Image to Registry") {
            steps {
                // https://docs.aws.amazon.com/AmazonECR/latest/userguide/registry_auth.html
                withCredentials([
                    string(credentialsId: 'aws_access_key_id',     variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'aws_secret_access_key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'aws_session_token',     variable: 'AWS_SESSION_TOKEN')
                ]) {
                    sh """
                        set -x
                        aws sts get-caller-identity --region ${env.AWS_REGION}
                    """
                    // script {
                    //     def loginPassword = sh(
                    //         script: "aws ecr get-login-password --region ${env.AWS_REGION}",
                    //         returnStdout: true
                    //     ).trim()
                    //     sh "echo ${loginPassword}"
                    //     sh "echo '${loginPassword}' | docker login --username AWS --password-stdin ${REGISTRY}"
                    // }
                    // //sh "aws ecr get-login-password --region ${env.AWS_REGION} | docker login --username AWS --password-stdin ${REGISTRY}"
                    // sh "docker push ${STAGING_TAG}"
                }
            }
        }

        stage("Deploy to Local Staging") {
            steps {
                sh 'docker stop petclinic-staging || true'
                sh 'docker rm petclinic-staging || true'
                sh 'docker run -d --name petclinic-staging -p 8081:8080 ${IMAGE_TAG}'
                echo 'PetClinic staging running at http://localhost:8081/'
            }
        }
    }
}